.ipynb_checkpoints/
*/.ipynb_checkpoints/*
# =========================
# 1. OS & System Junk
# =========================
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
.attributes
**/.attributes
Thumbs.db

# =========================
# 2. Python & Jupyter
# =========================
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
**/.ipynb_checkpoints/
.pytest_cache/

# =========================
# 3. Virtual Environments 
# (Never push your whole Conda/Pip env!)
# =========================
.env
.venv
env/
venv/
ENV/
conda_env/

# =========================
# 4. Deep Learning & Model Weights
# (Prevents pushing massive Transformer checkpoints)
# =========================
*.pt
*.pth
*.safetensors
*.ckpt
lightning_logs/
wandb/
runs/

# =========================
# 5. Data & Graph/Molecular Files
# (Prevents pushing raw structural data or giant datasets)
# =========================
*.csv
*.h5
*.hdf5
*.pdb
*.sdf
*.mol2
data/
datasets/

# =========================
# 6. IDE & Editor Settings
# =========================
.vscode/
.idea/
*.swp
